# ghostty configuration file

gtk-single-instance = true

font-family = JetBrainsMono Nerd Font
font-style = Regular
font-size = 16

theme = GitHub Dark Dimmed

cursor-color = #57ab5a
cursor-style = bar
cursor-style-blink = true
# click to move: alt+click
cursor-click-to-move = true

background-opacity = 0.75
background-blur = true

window-decoration = none

quick-terminal-position = top
quick-terminal-autohide = true
quick-terminal-size = 60%

shell-integration = zsh
shell-integration-features = no-cursor,no-sudo,title

macos-auto-secure-input = true
macos-secure-input-indication = true
macos-option-as-alt = true

auto-update = off

keybind = global:ctrl+`=toggle_quick_terminal

# disable native macos tabs/windows to enforce tmux usage
keybind = cmd+n=unbind

# tmux integration (all using ctrl-a prefix = \x01)
keybind = cmd+t=text:\x01\x63
keybind = cmd+w=text:\x01\x26
keybind = cmd+1=text:\x011
keybind = cmd+2=text:\x012
keybind = cmd+3=text:\x013
keybind = cmd+4=text:\x014
keybind = cmd+5=text:\x015

command = /opt/homebrew/bin/tmux new-session -A -s main

