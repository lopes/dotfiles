# ghostty configuration file

gtk-single-instance = true

font-family = JetBrainsMono Nerd Font
font-style = Regular
font-size = 16

theme = GitHub Dark Dimmed

bell-features = system, no-audio, no-attention, no-title, no-border

cursor-color = #57ab5a
cursor-style = bar
cursor-style-blink = true
# click to move: alt+click
cursor-click-to-move = true

background-opacity = 0.75
background-blur = true

window-decoration = none

quick-terminal-position = top
quick-terminal-autohide = true
quick-terminal-size = 60%

shell-integration = zsh
shell-integration-features = no-cursor,no-sudo,title

macos-auto-secure-input = true
macos-secure-input-indication = true
macos-option-as-alt = true

auto-update = off

keybind = global:ctrl+`=toggle_quick_terminal

# disable native macos tabs/windows to enforce tmux usage
keybind = cmd+n=unbind
keybind = cmd+t=unbind
keybind = cmd+w=unbind

command = /opt/homebrew/bin/tmux new-session -A -s main

